generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model admissions {
  id                     String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id                String                @unique @db.Uuid
  counselling_session_id String?               @db.Uuid
  course_id              String?               @db.Uuid
  batch_id               String?               @db.Uuid
  admission_date         DateTime              @default(dbgenerated("CURRENT_DATE")) @db.Date
  registration_fee       Decimal               @default(0) @db.Decimal(12, 2)
  total_fee              Decimal               @default(0) @db.Decimal(12, 2)
  amount_paid            Decimal               @default(0) @db.Decimal(12, 2)
  payment_status         String                @default("PENDING")
  payment_plan           String?
  converted_by_user_id   String?               @db.Uuid
  notes                  String?
  metadata               Json                  @default("{}")
  created_at             DateTime              @default(now()) @db.Timestamptz(6)
  updated_at             DateTime              @default(now()) @db.Timestamptz(6)
  counselling_sessions   counselling_sessions? @relation(fields: [counselling_session_id], references: [id], onUpdate: NoAction)
  leads                  leads                 @relation(fields: [lead_id], references: [id], onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model contact_attempts {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id              String               @db.Uuid
  campaign_id          String?              @db.Uuid
  direction            String               @default("OUTBOUND")
  contact_channel      String               @default("PHONE")
  contacted_by_type    String
  contacted_by_user_id String?              @db.Uuid
  ai_agent_id          String?              @db.Uuid
  attempt_number       Int
  status               String
  outcome              String?
  disposition          String?
  provider             String?
  provider_call_id     String?
  started_at           DateTime?            @db.Timestamptz(6)
  ringing_at           DateTime?            @db.Timestamptz(6)
  answered_at          DateTime?            @db.Timestamptz(6)
  ended_at             DateTime?            @db.Timestamptz(6)
  duration_seconds     Int?
  transcript           String?
  summary              String?
  recording_url        String?
  cost_amount          Decimal?             @db.Decimal(12, 4)
  currency             String               @default("INR")
  failure_reason       String?
  metadata             Json                 @default("{}")
  created_at           DateTime             @default(now()) @db.Timestamptz(6)
  updated_at           DateTime             @default(now()) @db.Timestamptz(6)
  leads                leads                @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  follow_ups           follow_ups[]
  lead_stage_history   lead_stage_history[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model counselling_sessions {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id             String       @db.Uuid
  counsellor_id       String?      @db.Uuid
  scheduled_at        DateTime     @db.Timestamptz(6)
  started_at          DateTime?    @db.Timestamptz(6)
  completed_at        DateTime?    @db.Timestamptz(6)
  session_type        String       @default("PHONE")
  status              String       @default("SCHEDULED")
  interest_level      String?
  outcome             String?
  pending_reason      String?
  no_admission_reason String?
  next_action_type    String?
  next_follow_up_at   DateTime?    @db.Timestamptz(6)
  counsellor_notes    String?
  metadata            Json         @default("{}")
  created_at          DateTime     @default(now()) @db.Timestamptz(6)
  updated_at          DateTime     @default(now()) @db.Timestamptz(6)
  admissions          admissions[]
  leads               leads        @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model follow_ups {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id            String            @db.Uuid
  contact_attempt_id String?           @db.Uuid
  reason             String
  status             String            @default("PENDING")
  priority           String            @default("NORMAL")
  assigned_to_type   String
  assigned_user_id   String?           @db.Uuid
  ai_agent_id        String?           @db.Uuid
  scheduled_at       DateTime          @db.Timestamptz(6)
  completed_at       DateTime?         @db.Timestamptz(6)
  resolution         String?
  notes              String?
  created_by_type    String
  created_by_user_id String?           @db.Uuid
  created_at         DateTime          @default(now()) @db.Timestamptz(6)
  updated_at         DateTime          @default(now()) @db.Timestamptz(6)
  contact_attempts   contact_attempts? @relation(fields: [contact_attempt_id], references: [id], onUpdate: NoAction)
  leads              leads             @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model lead_attributions {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id               String                 @db.Uuid
  ingestion_event_id    String?                @db.Uuid
  submission_channel    String
  acquisition_source    String
  acquisition_medium    String?
  touch_type            String                 @default("CONVERSION_TOUCH")
  utm_source            String?
  utm_medium            String?
  utm_campaign          String?
  utm_content           String?
  utm_term              String?
  campaign_id           String?
  campaign_name         String?
  ad_set_id             String?
  ad_set_name           String?
  ad_id                 String?
  ad_name               String?
  form_id               String?
  form_name             String?
  fbclid                String?
  gclid                 String?
  msclkid               String?
  landing_page_url      String?
  form_page_url         String?
  referrer_url          String?
  source_created_at     DateTime?              @db.Timestamptz(6)
  captured_at           DateTime               @default(now()) @db.Timestamptz(6)
  metadata              Json                   @default("{}")
  created_at            DateTime               @default(now()) @db.Timestamptz(6)
  lead_ingestion_events lead_ingestion_events? @relation(fields: [ingestion_event_id], references: [id], onUpdate: NoAction)
  leads                 leads                  @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model lead_ingestion_events {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id           String?             @db.Uuid
  ingestion_source  String
  external_event_id String?
  raw_payload       Json
  raw_headers       Json                @default("{}")
  processing_status String              @default("PENDING")
  processing_error  String?
  received_at       DateTime            @default(now()) @db.Timestamptz(6)
  processed_at      DateTime?           @db.Timestamptz(6)
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  lead_attributions lead_attributions[]
  leads             leads?              @relation(fields: [lead_id], references: [id], onUpdate: NoAction)

  @@unique([ingestion_source, external_event_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model lead_stage_history {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id            String            @db.Uuid
  contact_attempt_id String?           @db.Uuid
  from_stage         String?
  to_stage           String
  changed_by_type    String
  changed_by_user_id String?           @db.Uuid
  reason_code        String?
  notes              String?
  metadata           Json              @default("{}")
  changed_at         DateTime          @default(now()) @db.Timestamptz(6)
  contact_attempts   contact_attempts? @relation(fields: [contact_attempt_id], references: [id], onUpdate: NoAction)
  leads              leads             @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model leads {
  id                      String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name               String
  phone_raw               String?
  normalized_phone        String
  email                   String?
  city                    String?
  state                   String?
  education_qualification String?
  preferred_language      String?
  interested_course_id    String?                 @db.Uuid
  lifecycle_stage         String                  @default("NEW")
  contact_status          String                  @default("NOT_ATTEMPTED")
  admission_outcome       String                  @default("NOT_APPLICABLE")
  last_contact_outcome    String?
  latest_disposition      String?
  assigned_user_id        String?                 @db.Uuid
  current_owner_type      String?
  next_action_type        String?
  next_action_at          DateTime?               @db.Timestamptz(6)
  next_action_owner_type  String?
  next_action_owner_id    String?                 @db.Uuid
  lead_score              Int                     @default(0)
  priority                String                  @default("NORMAL")
  contact_attempt_count   Int                     @default(0)
  first_contacted_by_type String?
  last_contacted_by_type  String?
  first_received_at       DateTime                @default(now()) @db.Timestamptz(6)
  first_attempt_at        DateTime?               @db.Timestamptz(6)
  first_connected_at      DateTime?               @db.Timestamptz(6)
  last_contacted_at       DateTime?               @db.Timestamptz(6)
  last_enquiry_at         DateTime                @default(now()) @db.Timestamptz(6)
  do_not_call             Boolean                 @default(false)
  closed_reason           String?
  closed_at               DateTime?               @db.Timestamptz(6)
  profile_metadata        Json                    @default("{}")
  created_at              DateTime                @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                @default(now()) @db.Timestamptz(6)
  admissions              admissions?
  contact_attempts        contact_attempts[]
  counselling_sessions    counselling_sessions[]
  follow_ups              follow_ups[]
  lead_attributions       lead_attributions[]
  lead_ingestion_events   lead_ingestion_events[]
  lead_stage_history      lead_stage_history[]
}
